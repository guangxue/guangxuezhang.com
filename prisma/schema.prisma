generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Account {
  id                       String  @id
  userId                   String
  type                     String
  provider                 String
  providerAccountId        String
  refresh_token            String?
  access_token             String?
  expires_at               Int?
  token_type               String?
  scope                    String?
  id_token                 String?
  session_state            String?
  refresh_token_expires_in Int?
  User                     User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Image {
  id        Int       @id @default(autoincrement())
  name      String    @unique @db.VarChar(58)
  data_url  String
  createdAt DateTime? @default(now()) @db.Timestamp(6)
}

model Post {
  id        Int       @id @default(autoincrement())
  title     String    @db.VarChar(58)
  intro     String    @db.VarChar(300)
  logo      String    @default("/default.svg") @db.VarChar(58)
  slug      String    @unique @db.VarChar(58)
  tags      String?   @db.VarChar(58)
  publish   DateTime?
  content   String
  draft     Boolean   @default(false)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Session {
  id           String   @id
  sessionToken String   @unique
  userId       String
  expires      DateTime
  User         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Settings {
  id        Int      @id @default(autoincrement())
  name      String   @unique @db.VarChar(60)
  value     String   @db.VarChar(60)
  role      Role?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model User {
  id            String    @id
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  role          Role?
  username      String?   @unique
  password      String?
  Account       Account[]
  Session       Session[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

enum Role {
  User
  Admin
}
